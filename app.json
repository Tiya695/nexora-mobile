{
  "expo": {
    "name": "Nexora",
    "slug": "nexora-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.nexora.fieldagent",
      "permissions": [
        "CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED", "VIBRATE"
      ]
    },
    "plugins": [
      "expo-camera",
      "expo-location",
      "expo-notifications",
      "@sentry/react-native"
    ],
    "extra": {}
  }
}